        "lines_limit": 8,
        "lines_inset_x": 4,
        "lines_font_size": 10,
        "lines_gap": 3,
        "line_max_lines": 2,
        "lines_pair_step": 2,
        "lines_pair_separator": "，",
        "note_field": null
      },
      "footer": {
        "label": "POETRY",
        "attribution_template": "— {author}",
        "dashed": true,
        "height": 18
      }
    },
    "648x480": {
      "preset_props": {
        "top_gap": 16,
        "gap": 8,
