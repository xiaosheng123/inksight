{
  "mode_id": "BIAS",
  "display_name": "认知偏差",
  "icon": "tips",
  "cacheable": true,
  "description": "每天认识一个认知偏差",
  "content": {
    "type": "llm_json",
    "prompt_template": "你是一位认知心理学教授。介绍一个认知偏差或心理学效应。\n用 JSON 输出：\n{{\"name_cn\": \"中文名（如：幸存者偏差）\", \"name_en\": \"英文名（如：Survivorship Bias）\", \"definition\": \"一句话定义（25字以内）\", \"example\": \"一个贴近日常生活的例子（40字以内）\", \"antidote\": \"如何避免（20字以内）\"}}\n要求：优先选择不那么常见、但仍适合日常理解的偏差，覆盖决策、记忆、社交、消费等不同领域；避免总是使用最常见的那几个示例，尤其尽量不要反复选择幸存者偏差、锚定效应、沉没成本、宜家效应这类高频偏差；例子要贴近生活，让人会心一笑。只输出 JSON。\n环境：{context}",
    "output_schema": {
      "name_cn": { "type": "string", "default": "幸存者偏差" },
      "name_en": { "type": "string", "default": "Survivorship Bias" },
      "definition": { "type": "string", "default": "只看到成功案例，忽略了失败的大多数" },
      "example": { "type": "string", "default": "\"大学辍学也能成功\" —— 你没看到辍学后找不到工作的那些人。" },
      "antidote": { "type": "string", "default": "主动寻找反面证据" }
    },
    "temperature": 0.8,
    "fallback": {
      "name_cn": "幸存者偏差",
      "name_en": "Survivorship Bias",
      "definition": "只看到成功案例，忽略了失败的大多数",
      "example": "\"大学辍学也能成功\" —— 你没看到辍学后找不到工作的那些人。",
      "antidote": "主动寻找反面证据"
    }
  },
  "layout": {
    "status_bar": { "line_width": 1, "dashed": false },
    "layout_engine": "component_tree",
    "body_preset": "bias_card",
    "preset_props": {
      "padding_x": 18,
      "padding_y": 8,
      "justify": "center",
      "gap": 8,
      "title_field": "name_cn",
      "title_font": "noto_serif_bold",
      "title_font_size": 18,
      "subtitle_field": "name_en",
      "subtitle_font_size": 11,
      "separator_width": 70,
      "definition_field": "definition",
      "definition_font_size": 14,
      "definition_max_lines": 2,
      "example_title": "日常举例",
      "example_field": "example",
      "example_font_size": 12,
      "example_max_lines": 3,
      "example_inset_x": 36,
      "show_antidote_divider": true,
      "antidote_divider_margin_x": 40,
      "antidote_label": "解药",
      "antidote_label_font_size": 12,
      "antidote_label_margin_x": 24,
      "antidote_field": "antidote",
      "antidote_font_size": 12,
      "antidote_max_lines": 2,
      "antidote_inset_x": 40
    },
    "footer": {
      "label": "BIAS",
      "attribution_template": "— Know Thyself"
    }
  },
