{
  "mode_id": "ALMANAC",
  "display_name": "Daily Almanac",
  "icon": "calendar",
  "cacheable": false,
  "description": "Lunar date, do and avoid guidance, auspicious positions, and a daily health tip",
  "content": {
    "type": "composite",
    "steps": [
      {
        "type": "computed",
        "provider": "daily_meta",
        "fallback": {
          "year": 2026,
          "day": 1,
          "month_cn": "January",
          "weekday_cn": "Monday",
          "lunar_date": "Lunar First Month Day One",
          "day_of_year": 1,
          "days_in_year": 365
        }
      },
      {
        "type": "computed",
        "provider": "almanac_api",
        "fallback": {
          "solar_term": "",
          "lunar_date_display": "Second Lunar Month Twenty-Second Day",
          "yi": "Read, travel, meet friends",
          "ji": "Groundbreaking, lawsuits",
          "shenwei": "Joy God: Southeast Fortune God: Southwest Wealth God: South",
          "xingsu": "Southern Star Horse",
          "suisha": "Sha in the North",
          "chongsha": "Dog day clashes with Dragon",
          "health_tip": "Keep a steady routine and dress for the season."
        }
      }
    ],
    "fallback": {}
  },
  "layout": {
    "layout_engine": "component_tree",
    "status_bar": {
      "line_width": 2,
      "dashed": false
    },
    "component_theme": {
      "body_font": "lora_regular",
      "body_font_size": 11,
      "body_line_gap": 4,
      "section_title_font": "lora_bold",
      "section_title_font_size": 13,
      "section_title_gap": 2,
      "section_content_indent": 28,
      "section_content_gap": 3
    },
    "body": {
      "type": "column",
      "padding_x": 10,
      "padding_y": 12,
      "gap": 6,
      "children": [
        {
          "type": "row",
          "gap": 12,
          "align": "center",
          "children": [
            {
              "type": "box",
              "width": 112,
              "children": [
                {
                  "type": "column",
                  "gap": 5,
                  "children": [
                    {
                      "type": "big_number",
                      "field": "day",
                      "font_size": 48,
                      "align": "center"
                    },
                    {
                      "type": "text",
                      "field": "month_cn",
                      "font_size": 14,
                      "align": "center",
                      "max_lines": 1
                    },
                    {
                      "type": "text",
                      "field": "weekday_cn",
                      "font_size": 12,
                      "align": "center",
                      "max_lines": 1
                    },
                    {
                      "type": "text",
                      "field": "solar_term",
                      "font": "lora_bold",
                      "font_size": 16,
                      "align": "center",
                      "max_lines": 1
                    }
                  ]
                }
              ]
            },
            {
              "type": "box",
              "grow": 1,
              "padding_x": 8,
              "children": [
                {
                  "type": "column",
                  "gap": 5,
                  "children": [
                    {
                      "type": "text",
                      "template": "Lunar {lunar_date_display}",
                      "font_size": 12,
                      "font": "lora_bold",
                      "max_lines": 1
                    },
                    {
                      "type": "section_box",
                      "title": "Do",
                      "children": [
                        {
                          "type": "text",
                          "field": "yi",
                          "font": "lora_regular",
                          "font_size": 12,
                          "max_lines": 2
                        }
                      ]
                    },
                    {
                      "type": "section_box",
                      "title": "Avoid",
                      "children": [
                        {
                          "type": "text",
                          "field": "ji",
                          "font": "lora_regular",
                          "font_size": 12,
                          "max_lines": 2
                        }
                      ]
                    },
                    {
                      "type": "separator",
                      "style": "dashed"
                    },
                    {
                      "type": "section_box",
                      "title": "Positions",
                      "children": [
                        {
                          "type": "text",
                          "field": "shenwei",
                          "font": "lora_regular",
                          "font_size": 11,
                          "max_lines": 2
                        }
                      ]
                    },
                    {
                      "type": "text",
                      "template": "Star Lodge {xingsu}",
                      "font": "lora_regular",
                      "font_size": 10,
                      "max_lines": 1
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "spacer",
          "height": 4
        },
        {
          "type": "text",
          "field": "health_tip",
          "font": "lora_regular",
          "align": "center",
          "font_size": 12,
          "max_lines": 2
        }
      ]
    },
    "footer": {
      "label": "Almanac",
      "attribution_template": "{solar_term}",
      "line_width": 2
    }
  },
