{
  "mode_id": "RIDDLE",
  "display_name": "Daily Riddle",
  "icon": "tips",
  "cacheable": true,
  "description": "A fun riddle, brain teaser, or trivia question",
  "content": {
    "type": "llm_json",
    "prompt_template": "You are a riddle master. Based on the environment info, create a fun puzzle (riddle, brain teaser, or trivia — pick one).\nOutput JSON:\n{{\"category\": \"Type (Riddle / Brain Teaser / Trivia)\", \"question\": \"The question (under 80 chars)\", \"hint\": \"A hint (under 30 chars)\", \"answer\": \"The answer (under 30 chars)\"}}\nRequirements: Fun, medium difficulty, suitable for all ages. Output JSON only.\nContext: {context}",
    "output_schema": {
      "category": {
        "type": "string",
        "default": "Riddle"
      },
      "question": {
        "type": "string",
        "default": "I have cities, but no houses. I have mountains, but no trees. What am I?"
      },
      "hint": {
        "type": "string",
        "default": "You use me to find places."
      },
      "answer": {
        "type": "string",
        "default": "A map"
      }
    },
    "temperature": 0.9,
    "fallback": {
      "category": "Riddle",
      "question": "I have cities, but no houses. I have mountains, but no trees. What am I?",
      "hint": "You use me to find places.",
      "answer": "A map"
    }
  },
  "layout": {
    "layout_engine": "component_tree",
    "status_bar": {
      "line_width": 1,
      "dashed": false
    },
    "body_preset": "riddle_card",
    "preset_props": {
      "top_gap": 10,
      "meta_field": "category",
      "meta_font": "noto_serif_light",
      "meta_font_size": 11,
      "separator_width": 60,
      "question_inset_x": 26,
      "question_field": "question",
      "question_font": "noto_serif_bold",
      "question_font_size": 18,
      "question_max_lines": 4,
      "hint_field": "hint",
      "hint_template": "Hint: {hint}",
      "hint_font": "noto_serif_light",
      "hint_font_size": 11,
      "hint_max_lines": 2,
      "answer_divider_margin_x": 60,
      "answer_field": "answer",
      "answer_font": "noto_serif_regular",
      "answer_font_size": 12
    },
    "footer": {
      "label": "Riddle",
      "attribution_template": "— Think About It"
    }
  },
  "layout_overrides": {
    "296x128": {
      "preset_props": {
        "top_gap": 0,
        "gap": 6,
        "meta_font_size": 9,
        "separator_width": 40,
        "question_inset_x": 10,
        "question_font_size": 13,
        "question_max_lines": 3,
        "hint_field": null,
        "show_answer_divider": false,
        "answer_font_size": 10
      },
      "footer": {
        "label": "Riddle",
        "attribution_template": "— Think About It",
        "height": 18
      }
    },
    "648x480": {
      "preset_props": {
        "top_gap": 12,
        "gap": 10,
        "meta_font_size": 12,
        "separator_width": 68,
        "question_inset_x": 44,
        "question_font_size": 20,
        "question_max_lines": 4,
        "hint_font_size": 12,
        "answer_divider_margin_x": 58,
        "answer_font_size": 14
      }
    },
"640x384": {
        "preset_props": {
            "top_gap": 12,
            "gap": 6,
            "meta_font_size": 9,
            "separator_width": 68,
            "question_inset_x": 44,
            "question_font_size": 11,
            "question_max_lines": 3,
            "hint_font_size": 9,
            "answer_divider_margin_x": 58,
            "answer_font_size": 9
        }
    },
    "800x480": {
      "preset_props": {
        "top_gap": 16,
        "gap": 14,
        "meta_font_size": 15,
        "separator_width": 90,
        "question_inset_x": 70,
        "question_font_size": 26,
        "question_max_lines": 4,
        "hint_font_size": 15,
        "answer_divider_margin_x": 90,
        "answer_font_size": 18
      }
    }
  }
}
