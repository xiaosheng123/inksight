        "weekday_font_size": 11,
        "progress_width": 92,
        "season_font": "noto_serif_light",
        "season_font_size": 10,
        "season_inset_x": 10,
        "content_padding_x": 6,
        "quote_font": "noto_serif_regular",
        "quote_font_size": 16,
        "quote_max_lines": 3,
        "author_template": "— {author}",
        "author_font_size": 12,
        "book_title_font_size": 12,
        "book_title_max_lines": 2,
        "book_author_template": "by {book_author}",
        "book_author_font_size": 11,
