{
  "mode_id": "CHALLENGE",
  "display_name": "Micro Challenge",
  "icon": "flag",
  "cacheable": true,
  "description": "A quick 5-minute challenge to spark your day",
  "content": {
    "type": "llm_json",
    "prompt_template": "You are a life coach. Design a micro-challenge that can be done today in just 5 minutes, bringing a sense of freshness or small achievement.\nOutput JSON:\n{{\"challenge\": \"What to do (under 50 chars, specific and actionable)\", \"why\": \"Why it's worth doing (under 40 chars)\", \"difficulty\": \"Difficulty 1-3 stars (use ★)\", \"time\": \"Estimated time (e.g. 5 min)\"}}\nRequirements:\n1. Specific, actionable, no special tools needed\n2. Related to current weather/time if possible\n3. Cover social, creative, physical, sensory, thinking dimensions\n4. All text must be in English\nOutput JSON only.\nContext: {context}",
    "output_schema": {
      "challenge": {
        "type": "string",
        "default": "Write a 6-word story about your morning"
      },
      "why": {
        "type": "string",
        "default": "Constraints spark creativity"
      },
      "difficulty": {
        "type": "string",
        "default": "★"
      },
      "time": {
        "type": "string",
        "default": "5 min"
      }
    },
    "temperature": 0.9,
    "fallback": {
      "challenge": "Write a 6-word story about your morning",
      "why": "Constraints spark creativity",
      "difficulty": "★",
      "time": "5 min"
    }
  },
  "layout": {
    "status_bar": {
      "line_width": 1,
      "dashed": false
    },
    "layout_engine": "component_tree",
    "body_preset": "prompt_card",
    "preset_props": {
      "padding_x": 18,
      "padding_y": 8,
      "justify": "center",
      "gap": 8,
      "title_template": "Today's Challenge",
      "title_font": "noto_serif_bold",
      "title_font_size": 14,
      "meta_template": "{difficulty}  ·  {time}",
      "meta_font_size": 11,
      "separator_width": 60,
      "hero_inset_x": 40,
      "hero_field": "challenge",
      "hero_font": "noto_serif_bold",
      "hero_font_size": 18,
      "hero_max_lines": 3,
      "note_field": "why",
      "note_font": "noto_serif_light",
      "note_font_size": 11,
      "note_max_lines": 2,
      "note_divider_margin_x": 50
    },
    "footer": {
      "label": "Challenge",
      "attribution_template": "— Just Do It"
    }
  },
  "layout_overrides": {
    "296x128": {
      "preset_props": {
        "padding_x": 8,
        "padding_y": 4,
        "gap": 6,
        "title_template": null,
        "meta_font_size": 9,
        "separator_width": 40,
        "hero_inset_x": 8,
        "hero_font_size": 13,
        "hero_max_lines": 3,
        "note_field": null,
        "show_note_divider": false
      },
      "footer": {
        "label": "Challenge",
        "attribution_template": "— Just Do It",
        "height": 18
      }
    },
    "648x480": {
      "preset_props": {
        "padding_x": 20,
        "padding_y": 10,
        "gap": 9,
        "title_font_size": 16,
        "meta_font_size": 12,
        "separator_width": 68,
        "hero_inset_x": 56,
        "hero_font_size": 20,
        "hero_max_lines": 3,
        "note_font_size": 12,
        "note_max_lines": 3,
        "note_divider_margin_x": 54
      }
    },
"640x384": {
        "preset_props": {
            "padding_x": 20,
            "padding_y": 6,
            "gap": 6,
            "title_font_size": 9,
            "meta_font_size": 9,
            "separator_width": 68,
            "hero_inset_x": 56,
            "hero_font_size": 11,
            "hero_max_lines": 2,
            "note_font_size": 9,
            "note_max_lines": 2,
            "note_divider_margin_x": 54
        }
    },
    "800x480": {
      "preset_props": {
        "padding_x": 28,
        "padding_y": 14,
        "gap": 12,
        "title_font_size": 20,
        "meta_font_size": 15,
        "separator_width": 90,
        "hero_inset_x": 112,
        "hero_font_size": 26,
        "hero_max_lines": 3,
        "note_font_size": 16,
        "note_max_lines": 3,
        "note_divider_margin_x": 80
      }
    }
  }
}
