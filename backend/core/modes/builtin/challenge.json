            "hero_font_size": 11,
            "hero_max_lines": 2,
            "note_font_size": 9,
            "note_max_lines": 2,
            "note_divider_margin_x": 54
        }
    },
    "800x480": {
      "preset_props": {
        "padding_x": 28,
