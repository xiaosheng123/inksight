      },
      {
        "type": "llm",
        "prompt_template": "今天是{context}。{reminder_hint}请用一句话(15字以内)给出今天的提醒或小知识，如果有提醒事项请优先围绕提醒事项来说。只输出文字。",
        "output_format": "text",
        "fallback": { "text": "日拱一卒 功不唐捐" }
      }
    ],
    "fallback": {},
    "fallback_pool": [
      {
        "calendar_title": "2026年3月",
